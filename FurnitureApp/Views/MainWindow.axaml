<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FurnitureApp.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="FurnitureApp.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="FurnitureApp"
        xmlns:comp="using:FurnitureApp.Views.Components"
        xmlns:dto="using:FurnitureApp.DTOs">
    <!--суда тоже подключаем компоненты и ДТО-->
    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>
    
        <Grid Margin="10" RowDefinitions="Auto, *">
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10" Spacing="10">
                <TextBox Watermark="Поиск по наименованию"
                         Text="{Binding SearchText}"
                         MaxWidth="300"
                         MinWidth="300"/>
                <ComboBox ItemsSource="{Binding ProductTypes}"
                          SelectedItem="{Binding SelectedProductType}"
                          MinWidth="150"
                          MaxWidth="150"/>
            </StackPanel>
        
            <ScrollViewer Grid.Row="1">
                <!-- берем из вью модела MainWindowViewModel, там есть пропс под итем-->
                <ItemsControl ItemsSource="{Binding ProductCardItems}">
                    <ItemsControl.ItemTemplate>
                        <!--получаем данные из ДТО и передаем его в компонент карточки -->
                        <DataTemplate x:DataType="dto:ProductCardItem">
                            <comp:ProductCard Margin="10"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            
        </Grid>

    
</Window>
